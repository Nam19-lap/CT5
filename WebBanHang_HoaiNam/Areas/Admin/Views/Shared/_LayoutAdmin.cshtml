@using Microsoft.AspNetCore.Identity
@using WebBanHang_HoaiNam.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.5.0/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body {
            margin: 0;
            padding: 0;
        }

        .sidebar {
            width: 250px;
            min-height: 100vh;
        }

            .sidebar .nav-link {
                color: #fff;
            }

                .sidebar .nav-link.active {
                    background-color: #495057;
                    border-radius: 5px;
                }

        .topbar {
            height: 60px;
        }
    </style>
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <nav class="sidebar bg-dark p-3">
            <h4 class="text-center text-white mb-4">Admin Panel</h4>
            <ul class="nav flex-column">
                <li class="nav-item mb-2">
                    <a class="nav-link @(ViewData["ActiveMenu"] as string == "Product" ? "active" : "")"
                       asp-area="Admin" asp-controller="Product" asp-action="Index">
                        <i class="bi bi-box-seam"></i> Quản lý sản phẩm
                    </a>
                </li>
                <li class="nav-item mb-2">
                    <a class="nav-link @(ViewData["ActiveMenu"] as string == "Categories" ? "active" : "")"
                       asp-area="Admin" asp-controller="Categories" asp-action="Index">
                        <i class="bi bi-tags"></i> Quản lý danh mục
                    </a>
                </li>
            </ul>
        </nav>

        <!-- Main content -->
        <div class="flex-grow-1">
            <!-- Topbar -->
            <nav class="navbar navbar-expand navbar-light bg-light topbar px-3 border-bottom">
                <div class="ms-auto d-flex align-items-center">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <span class="me-3">Xin chào <strong>@UserManager.GetUserName(User)</strong>!</span>
                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home")" method="post" class="d-inline">
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-box-arrow-right"></i> Logout
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-primary btn-sm me-2">
                            <i class="bi bi-box-arrow-in-right"></i> Login
                        </a>
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-success btn-sm">
                            <i class="bi bi-person-plus"></i> Register
                        </a>
                    }
                </div>
            </nav>

            <!-- Body -->
            <div class="p-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
