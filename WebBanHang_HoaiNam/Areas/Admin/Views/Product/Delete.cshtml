@model WebBanHang_HoaiNam.Models.Product

@{
    ViewData["Title"] = "Xóa sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-lg border-danger">
        <div class="card-header bg-danger text-white">
            <h4><i class="bi bi-trash"></i> Xóa sản phẩm</h4>
        </div>
        <div class="card-body">
            <div class="alert alert-warning">
                <h5><i class="bi bi-exclamation-triangle"></i> Cảnh báo</h5>
                <p>Bạn có chắc chắn muốn xóa sản phẩm này? Hành động này không thể hoàn tác.</p>
            </div>

            <dl class="row">
                <dt class="col-sm-3 fw-bold">Tên sản phẩm</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>

                <dt class="col-sm-3 fw-bold">Giá</dt>
                <dd class="col-sm-9">@Model.Price.ToString("N0") đ</dd>

                <dt class="col-sm-3 fw-bold">Danh mục</dt>
                <dd class="col-sm-9">@Model.Category?.Name</dd>

                <dt class="col-sm-3 fw-bold">Mô tả</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Description)</dd>

                <dt class="col-sm-3 fw-bold">Ảnh</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Name" style="width:120px;height:auto;" class="img-thumbnail" />
                    }
                    else
                    {
                        <span class="text-muted">Không có ảnh</span>
                    }
                </dd>
            </dl>

            <form asp-action="DeleteConfirmed" method="post" class="mt-4">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex justify-content-start">
                    <button type="submit" class="btn btn-danger me-2">
                        <i class="bi bi-trash-fill"></i> Xóa
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="mt-4">
        <div class="card border-info">
            <div class="card-header bg-info text-white">
                <h5><i class="bi bi-info-circle"></i> Thông tin thêm</h5>
            </div>
            <div class="card-body">
                <p>
                    Khi bạn xóa sản phẩm, dữ liệu liên quan sẽ bị mất khỏi hệ thống.
                    Hãy chắc chắn rằng bạn đã kiểm tra kỹ trước khi thực hiện.
                </p>
                <ul>
                    <li>Sản phẩm sẽ bị xóa vĩnh viễn.</li>
                    <li>Ảnh và mô tả sản phẩm sẽ không còn hiển thị.</li>
                    <li>Hành động này không thể hoàn tác.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
