@model IEnumerable<WebBanHang_HoaiNam.Models.Product>

@{
    ViewData["Title"] = "Danh sách sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-lg">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <h4><i class="bi bi-box-seam"></i> Danh sách sản phẩm</h4>
            <a asp-action="Add" class="btn btn-light text-success fw-bold">
                <i class="bi bi-plus-circle"></i> Thêm sản phẩm mới
            </a>
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> Hiện chưa có sản phẩm nào trong hệ thống.
                </div>
            }
            else
            {
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th scope="col">Tên sản phẩm</th>
                            <th scope="col">Giá</th>
                            <th scope="col">Danh mục</th>
                            <th scope="col">Mô tả</th>
                            <th scope="col">Ảnh</th>
                            <th scope="col" class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td>@item.Price.ToString("N0") đ</td>
                                <td>@item.Category?.Name</td>
                                <td>@item.Description</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.Name" style="width:80px;height:auto;" class="img-thumbnail" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">Không có ảnh</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">
                                        <i class="bi bi-pencil-square"></i> Sửa
                                    </a>
                                    <a asp-action="Display" asp-route-id="@item.Id" class="btn btn-sm btn-info me-1">
                                        <i class="bi bi-eye"></i> Xem
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <div class="mt-4">
        <div class="card border-secondary">
            <div class="card-header bg-secondary text-white">
                <h5><i class="bi bi-journal-text"></i> Ghi chú</h5>
            </div>
            <div class="card-body">
                <p>
                    Đây là danh sách tất cả sản phẩm hiện có trong hệ thống.
                    Bạn có thể thêm mới, chỉnh sửa, xem chi tiết hoặc xóa sản phẩm tùy theo nhu cầu quản lý.
                </p>
                <ul>
                    <li>Giá sản phẩm được hiển thị theo định dạng tiền tệ Việt Nam.</li>
                    <li>Ảnh sản phẩm giúp người dùng dễ nhận diện hơn.</li>
                    <li>Hãy đảm bảo thông tin sản phẩm đầy đủ và chính xác.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
