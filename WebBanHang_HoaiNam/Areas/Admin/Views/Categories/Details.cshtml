@model WebBanHang_HoaiNam.Models.Category

@{
    ViewData["Title"] = "Chi tiết danh mục";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-lg">
        <div class="card-header bg-info text-white">
            <h4><i class="bi bi-info-circle"></i> Thông tin chi tiết danh mục</h4>
        </div>
        <div class="card-body">
            <div class="alert alert-primary">
                <p>Đây là thông tin chi tiết của danh mục bạn đã chọn. Bạn có thể chỉnh sửa hoặc xóa nếu cần.</p>
            </div>

            <dl class="row">
                <dt class="col-sm-3 fw-bold">
                    @Html.DisplayNameFor(model => model.Name)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Name)
                </dd>
            </dl>

            <hr />

            <div class="mt-3">
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning me-2">
                    <i class="bi bi-pencil-square"></i> Sửa
                </a>
                <a asp-action="Delete" asp-route-id="@Model?.Id" class="btn btn-danger me-2">
                    <i class="bi bi-trash"></i> Xóa
                </a>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại danh sách
                </a>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <div class="card border-secondary">
            <div class="card-header bg-secondary text-white">
                <h5><i class="bi bi-journal-text"></i> Ghi chú</h5>
            </div>
            <div class="card-body">
                <p>
                    Danh mục này có thể liên kết với nhiều sản phẩm trong hệ thống.
                    Khi bạn chỉnh sửa hoặc xóa, hãy đảm bảo rằng các sản phẩm liên quan
                    được cập nhật phù hợp để tránh lỗi hiển thị.
                </p>
                <ul>
                    <li>Danh mục giúp phân loại sản phẩm rõ ràng.</li>
                    <li>Thông tin danh mục ảnh hưởng đến trải nghiệm người dùng.</li>
                    <li>Hãy kiểm tra kỹ trước khi thực hiện thay đổi.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
