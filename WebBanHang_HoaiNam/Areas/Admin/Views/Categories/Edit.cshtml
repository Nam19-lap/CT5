@model WebBanHang_HoaiNam.Models.Category

@{
    ViewData["Title"] = "Chỉnh sửa danh mục";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-lg">
        <div class="card-header bg-warning text-dark">
            <h4><i class="bi bi-pencil-square"></i> Chỉnh sửa danh mục</h4>
        </div>
        <div class="card-body">
            <div class="alert alert-info">
                <p>Bạn đang chỉnh sửa thông tin của danh mục. Hãy đảm bảo nhập dữ liệu chính xác trước khi lưu.</p>
            </div>

            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold">Tên danh mục</label>
                    <input asp-for="Name" class="form-control" placeholder="Nhập tên danh mục..." />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <hr />

                <div class="d-flex justify-content-start">
                    <button type="submit" class="btn btn-success me-2">
                        <i class="bi bi-check-circle"></i> Lưu thay đổi
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="mt-4">
        <div class="card border-secondary">
            <div class="card-header bg-secondary text-white">
                <h5><i class="bi bi-journal-text"></i> Ghi chú</h5>
            </div>
            <div class="card-body">
                <p>
                    Việc chỉnh sửa danh mục có thể ảnh hưởng đến nhiều sản phẩm liên quan.
                    Hãy kiểm tra kỹ trước khi lưu để tránh lỗi hiển thị hoặc dữ liệu không đồng bộ.
                </p>
                <ul>
                    <li>Danh mục giúp phân loại sản phẩm rõ ràng.</li>
                    <li>Thông tin danh mục ảnh hưởng đến trải nghiệm người dùng.</li>
                    <li>Hãy đảm bảo tên danh mục ngắn gọn, dễ hiểu.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
