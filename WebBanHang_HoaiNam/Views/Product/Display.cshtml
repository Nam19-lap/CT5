@model WebBanHang_HoaiNam.Models.Product

<div class="container mt-5">
    <div class="card shadow-lg border-0">
        <div class="row g-0">

            <!-- Ảnh sản phẩm -->
            <div class="col-md-5 text-center p-4">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl"
                         class="img-fluid rounded"
                         style="max-height:350px; object-fit:cover;" />
                }
                else
                {
                    <img src="/images/no-image.png"
                         class="img-fluid rounded"
                         style="max-height:350px;" />
                }
            </div>

            <!-- Thông tin sản phẩm -->
            <div class="col-md-7 p-4">
                <h2 class="fw-bold">@Model.Name</h2>

                <h3 class="text-danger mt-3">
                    @Model.Price.ToString("N0") VND
                </h3>

                <p class="text-muted mt-3">
                    @Model.Description
                </p>

                <hr />

                <!-- Nút thao tác -->
                <div class="mt-4 d-flex">
                    <a asp-action="Index" class="btn btn-secondary me-2">
                        ⬅ Quay lại
                    </a>

                    <form asp-controller="ShoppingCart" asp-action="AddToCart" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-success">
                            🛒 Thêm vào giỏ hàng
                        </button>
                    </form>
                </div>

                <!-- Chính sách -->
                <div class="mt-4">
                    <h6>🔄 Chính sách đổi trả</h6>
                    <p>Đổi trả trong vòng 7 ngày nếu sản phẩm lỗi.</p>
                </div>
            </div>
        </div>
    </div>
</div>
