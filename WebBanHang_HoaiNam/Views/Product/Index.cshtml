@model IEnumerable<WebBanHang_HoaiNam.Models.Product>

@{
    ViewData["Title"] = "Sản phẩm";
    var numOfQuantity = 1;
}

<div class="container">

    <!-- Banner -->
    <div id="banner" class="carousel slide mb-5" data-bs-ride="carousel">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="https://images.unsplash.com/photo-1445205170230-053b83016050"
                     class="d-block w-100"
                     style="height:350px; object-fit:cover;">
            </div>
            <div class="carousel-item">
                <img src="https://images.unsplash.com/photo-1483985988355-763728e1935b"
                     class="d-block w-100"
                     style="height:350px; object-fit:cover;">
            </div>
            <div class="carousel-item">
                <img src="https://images.unsplash.com/photo-1490481651871-ab68de25d43d"
                     class="d-block w-100"
                     style="height:350px; object-fit:cover;">
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#banner" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#banner" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>

    <!-- Tiêu đề -->
    <h3 class="fw-bold mb-4">Danh sách sản phẩm</h3>

    <!-- Danh sách sản phẩm -->
    <div class="row g-4">
        @foreach (var product in Model)
        {
            <div class="col-md-3">
                <div class="card h-100 shadow-sm text-center p-3 product-card">
                    <!-- Hình -->
                    <a asp-action="Display" asp-route-id="@product.Id" class="text-decoration-none text-dark">
                        <img src="@product.ImageUrl"
                             class="card-img-top mb-3"
                             style="height:220px; object-fit:contain;" />
                        <!-- Tên -->
                        <h6 class="fw-bold" style="min-height:48px;">
                            @product.Name
                        </h6>
                    </a>
                    <!-- Giá -->
                    <p class="text-danger fw-bold fs-5">
                        @product.Price.ToString("N0") đ
                    </p>
                    <!-- Nút -->
                    <a asp-controller="ShoppingCart"
                       asp-action="AddToCart"
                       asp-route-productId="@product.Id"
                       asp-route-quantity="@numOfQuantity"
                       class="btn btn-warning w-100 fw-bold">
                        🛒 Thêm vào giỏ
                    </a>
                </div>
            </div>
        }
    </div>

    <!-- Ưu điểm -->
    <div class="row text-center mt-5">
        <div class="col-md-4">
            <h5>🚚 Giao hàng nhanh</h5>
            <p>2-3 ngày</p>
        </div>
        <div class="col-md-4">
            <h5>💰 Giá tốt</h5>
            <p>Hợp lý</p>
        </div>
        <div class="col-md-4">
            <h5>🔄 Đổi trả</h5>
            <p>7 ngày</p>
        </div>
    </div>
</div>

<!-- CSS chim bay -->
<style>
    .bird {
        position: fixed;
        left: -50px;
        z-index: 9999;
        will-change: transform;
    }

    keyframes fly {
        from

    {
        transform: translateX(0) translateY(0) rotate(0deg);
    }

    to {
        transform: translateX(110vw) translateY(-30px) rotate(360deg);
    }

    }

    keyframes flap {
        0%

    {
        transform: scale(1) rotate(0deg);
    }

    50% {
        transform: scale(1.1) rotate(10deg);
    }

    100% {
        transform: scale(1) rotate(0deg);
    }

    }

    .product-card:hover {
        transform: translateY(-5px);
        transition: 0.3s;
        box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }
</style>

<!-- JS chim bay -->
<script>
    function createBird(color, icon) {
        const bird = document.createElement("div");
        bird.className = "bird";
        bird.innerHTML = icon;

        // Random vị trí, kích thước, tốc độ
        bird.style.top = Math.random() * 300 + "px";
        bird.style.color = color;
        bird.style.fontSize = (Math.random() * 20 + 20) + "px";

        const duration = Math.random() * 6 + 6; // 6–12s
        bird.style.animation = `fly ${duration}s linear forwards, flap 1s infinite`;

        document.body.appendChild(bird);
        setTimeout(() => bird.remove(), duration * 1000);
    }

    function dove() {
        createBird("white", "🕊️");
    }

    function flock() {
        const colors = ["red", "blue", "green", "orange", "purple", "pink"];
        for (let i = 0; i < 8; i++) {
            setTimeout(() => {
                createBird(colors[i % colors.length], "🕊️");
            }, i * 300);
        }
    }

    setInterval(dove, 8000);
    setInterval(flock, 15000);
</script>
