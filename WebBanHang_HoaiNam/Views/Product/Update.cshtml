@model WebBanHang_HoaiNam.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Update Product";
}

<div class="container mt-4">

    <div class="card shadow-lg">

        <div class="card-header bg-warning text-dark">
            <h3 class="mb-0">Chỉnh sửa sản phẩm</h3>
        </div>

        <div class="card-body">

            <form asp-action="Update" enctype="multipart/form-data">

                <input type="hidden" asp-for="Id" />

                <div class="row">

                    <!-- Tên sản phẩm -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <!-- Giá -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label"></label>
                        <input asp-for="Price" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <!-- Ảnh -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="ImageUrl" class="form-label">Image</label>
                        <input type="file"
                               asp-for="ImageUrl"
                               class="form-control"
                               onchange="previewImage(event)" />
                    </div>

                    <!-- Preview ảnh -->
                    <div class="col-md-6 mb-3 text-center">
                        <img id="preview"
                             src="@Model.ImageUrl"
                             class="img-fluid rounded"
                             style="max-height:200px; object-fit:cover;" />
                    </div>

                    <!-- Mô tả -->
                    <div class="col-md-12 mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                </div>

                <div class="text-center mt-3">

                    <button type="submit" class="btn btn-success px-4">
                        Cập nhật
                    </button>

                    <a asp-action="Index" class="btn btn-secondary px-4">
                        Quay lại
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

<script>
    function previewImage(event) {
        const reader = new FileReader();
        reader.onload = function () {
            document.getElementById("preview").src = reader.result;
        }
        reader.readAsDataURL(event.target.files[0]);
    }
</script>